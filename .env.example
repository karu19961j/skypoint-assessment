# Copy to .env before running `docker compose up --build`, then replace any
# value tagged `replace-with-…` with one of your own. See README
# §"Configuration & Secrets" for the local / CI / prod tier story.

# ---------- App ----------
# Controls how strict the boot-time secret checks are. `production`
# refuses to boot on a < 32-char or known-placeholder JWT secret;
# `test` turns the same check off so CI can use a short value.
APP_ENV=development

# ---------- Postgres ----------
# Read by the `postgres` container at first boot to create the role +
# database. Pick your own before any non-local use; the DATABASE_URL
# below must stay in sync with whatever you choose here.
POSTGRES_USER=sample_db_user
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=sample_db_name

# ---------- Backend ----------
# Generate your own with `openssl rand -hex 32`. Must be >= 32 chars
# and not one of the known-placeholder strings the backend's
# assert_production_ready() refuses (see backend/app/config.py).
JWT_SECRET=replace-with-openssl-rand-hex-32-output-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=30

# SQLAlchemy URL. Host is `postgres` (the compose service name);
# the user / password / database must match the POSTGRES_* values above.
DATABASE_URL=postgresql+psycopg://sample_db_user:replace-with-strong-postgres-password@postgres:5432/sample_db_name

# CORS — frontend origin. Used only in dev; in compose the frontend
# proxies /api same-origin via nginx so this stays unused.
CORS_ORIGINS=http://localhost:5173

# Seed credentials — backend/app/seed.py provisions one HR + one
# candidate from these on first boot so the assessor can log in
# without setup. The README documents them as the demo logins;
# change them here if you want different credentials.
SEED_HR_EMAIL=hr@test.com
SEED_HR_PASSWORD=Hr@1234
SEED_CANDIDATE_EMAIL=candidate@test.com
SEED_CANDIDATE_PASSWORD=Candidate@1234

# HR self-registration is OFF by default. HR accounts are provisioned
# via the seed (and in production would be provisioned via an
# admin/invite flow). Flip to true only if you want to allow public
# signup with role=hr.
ALLOW_HR_SELF_REGISTER=false

# ---------- MinIO (S3-compatible object storage for resumes) ----------
# MinIO runs as a docker-compose service; the backend uploads to it via
# boto3 over the docker network. Same boto3 calls work against real AWS
# S3 in production — only the endpoint + credentials change.
#
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD bootstrap the MinIO admin account
# (used by the backend as access/secret key). For production, you'd
# provision a scoped service user with PutObject/GetObject on the bucket
# rather than reusing root.
MINIO_ROOT_USER=replace-with-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-minio-root-password-min-8-chars
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=replace-with-minio-root-user
MINIO_SECRET_KEY=replace-with-minio-root-password-min-8-chars
MINIO_BUCKET=resumes
MINIO_REGION=us-east-1

# Max resume upload size in bytes (default 15 MiB). Enforced server-side;
# the frontend mirrors this for client-side feedback.
RESUME_MAX_BYTES=15728640

# Copy to .env before running `docker compose up --build`.
# All values below are safe defaults for local assessment use only.

# ---------- Postgres ----------
POSTGRES_USER=jobportal
POSTGRES_PASSWORD=jobportal_dev_password
POSTGRES_DB=jobportal

# ---------- Backend ----------
# This value is the assessor-only default so `docker compose up --build` works
# out of the box. Generate your own with `openssl rand -hex 32` before any
# non-local use. The app refuses to boot on a known-placeholder JWT_SECRET.
JWT_SECRET=assessment-only-2026-05-21-c6f3a8e2b41957d80fa17c45e8b29df3
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=30

# SQLAlchemy URL; host = "postgres" because that's the compose service name
DATABASE_URL=postgresql+psycopg://jobportal:jobportal_dev_password@postgres:5432/jobportal

# CORS — frontend origin (used only in dev; in compose the frontend proxies /api same-origin)
CORS_ORIGINS=http://localhost:5173

# Seed credentials (used by backend/app/seed.py on startup; documented in README)
SEED_HR_EMAIL=hr@test.com
SEED_HR_PASSWORD=Hr@1234
SEED_CANDIDATE_EMAIL=candidate@test.com
SEED_CANDIDATE_PASSWORD=Candidate@1234

# HR self-registration is disabled by default. Production should provision HR
# accounts via an admin/invite flow; for assessment demos the seeded HR user
# above is enough. Set to "true" to re-enable the HR option on /register.
ALLOW_HR_SELF_REGISTER=false
